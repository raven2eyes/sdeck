# Home Assistant connection
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-access-token-here

# Optional: restrict to specific Stream Deck serial number
# STREAMDECK_SERIAL=ABC123XYZ

# Default media player entity (without domain prefix)
MEDIA_PLAYER=entertainment

# Default light group entity (without domain prefix)
UPSTAIRS_LIGHTS=upstairs

# Timer entity name
TIMER_ENTITY=streamdeck

# Profiles directory (default: ./profiles)
# PROFILES_DIR=./profiles

# Templates directory (default: ./templates)
# TEMPLATES_DIR=./templates

# Log level
LOG_LEVEL=INFO
